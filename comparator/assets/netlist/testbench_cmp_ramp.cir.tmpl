* StrongArm Comparator — Ramp Input Testbench (clean, no noise injection)
* VDD={VDD}V, CLK=1GHz
* Vin_diff ramps from {vin_start_mv}mV to {vin_end_mv}mV over {n_cycles} cycles

* ── Supply and clock ──────────────────────────────────────────────────────────
VVDD VDD 0 DC {VDD}
VCLK CLK 0 PULSE(0 {VDD} 0 10p 10p 500p 1n)

* ── Input stimulus (clean PWL ramp, complementary around VCM) ────────────────
* INP = VCM + Vin_diff/2  (ramps up)
* INN = VCM - Vin_diff/2  (ramps down)
VINP INP 0 PWL(0 {vinp_start} {tstop} {vinp_end})
VINN INN 0 PWL(0 {vinn_start} {tstop} {vinn_end})

* ── DUT ───────────────────────────────────────────────────────────────────────
{dut_include}

X1 INP INN CLK VDD OUTP OUTN comparator_strongarm

* ── Initial conditions (reset state) ─────────────────────────────────────────
.ic V(x1.vxp)={VDD} V(x1.vxn)={VDD} V(x1.vlp)={VDD} V(x1.vln)={VDD} V(x1.vs)=0

.include {model_path}

.control
tran {tstep} {tstop} uic
wrdata {out_outp} v(outp)
wrdata {out_outn} v(outn)
wrdata {out_inp}  v(inp)
wrdata {out_inn}  v(inn)
.endc

.end
