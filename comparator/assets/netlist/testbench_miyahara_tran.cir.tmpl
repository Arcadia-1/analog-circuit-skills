* Miyahara Comparator — Transition Waveform Testbench
* Clean constant-input waveform: no injected noise.
* Records: CLK, INP/INN, VLP/VLN (latch nodes), OUTP/OUTN.
* VDD={VDD}V, CLK=1GHz, Vin_diff={vin_label}mV

* ── Supply and clock ──────────────────────────────────────────────────────────
VVDD VDD 0 DC {VDD}
VCLK CLK 0 PULSE(0 {VDD} 0 10p 10p 500p 1n)

* ── Input stimulus (constant DC, no noise injection) ─────────────────────────
VINP INP 0 DC {vinp_dc}
VINN INN 0 DC {vinn_dc}

* ── DUT ───────────────────────────────────────────────────────────────────────
{dut_include}

X1 INP INN CLK VDD OUTP OUTN comparator_miyahara

* ── Initial conditions (reset state: VLP=VLN=VDD, VS=0) ─────────────────────
.ic V(x1.vlp)={VDD} V(x1.vln)={VDD} V(x1.vs)=0

.include {model_path}

.options RELTOL=1e-4 METHOD=gear

.control
tran {tstep} {tstop} uic
wrdata {out_clk}   v(clk)
wrdata {out_inp}   v(inp)
wrdata {out_inn}   v(inn)
wrdata {out_vlp}   v(x1.vlp)
wrdata {out_vln}   v(x1.vln)
wrdata {out_outp}  v(outp)
wrdata {out_outn}  v(outn)
.endc

.end
