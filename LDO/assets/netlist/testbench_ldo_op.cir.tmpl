* LDO DC Operating-Point Analysis — Flat Netlist
* Each device parameter written to its own wrdata file (5 files per transistor).
* Technology: PTM 180nm  VIN={vin_dc}V  VREF={vref_dc}V  R_load={r_load}Omega

* ── DC Sources ───────────────────────────────────────────────────────────────
VIN_SRC   vin   0   DC {vin_dc}
VREF_SRC  vref  0   DC {vref_dc}
VVSS      vss   0   DC 0

* ── Bias current source ──────────────────────────────────────────────────────
I1  vin ibias DC {ibias_ua}u
C1  ibias vss {c_ibias}

* ── Current mirror (NMOS) ────────────────────────────────────────────────────
M6 ibias ibias vss vss NMOS L={l_m6} W={w_m6} m={m_m6}
+ ad={ad_m6} as={as_m6} pd={pd_m6} ps={ps_m6} nrd={nrd_m6} nrs={nrs_m6}
M5 net16 ibias vss vss NMOS L={l_m5} W={w_m5} m={m_m5}
+ ad={ad_m5} as={as_m5} pd={pd_m5} ps={ps_m5} nrd={nrd_m5} nrs={nrs_m5}

* ── Differential amplifier ───────────────────────────────────────────────────
M0 net3 vref  net16 vss NMOS L={l_m0} W={w_m0} m={m_m0}
+ ad={ad_m0} as={as_m0} pd={pd_m0} ps={ps_m0} nrd={nrd_m0} nrs={nrs_m0}
M1 net4 net30 net16 vss NMOS L={l_m1} W={w_m1} m={m_m1}
+ ad={ad_m1} as={as_m1} pd={pd_m1} ps={ps_m1} nrd={nrd_m1} nrs={nrs_m1}

* ── PMOS active load ─────────────────────────────────────────────────────────
M4 net4 net4 vin vin PMOS L={l_m4} W={w_m4} m={m_m4}
+ ad={ad_m4} as={as_m4} pd={pd_m4} ps={ps_m4} nrd={nrd_m4} nrs={nrs_m4}
M3 net3 net4 vin vin PMOS L={l_m3} W={w_m3} m={m_m3}
+ ad={ad_m3} as={as_m3} pd={pd_m3} ps={ps_m3} nrd={nrd_m3} nrs={nrs_m3}

* ── Pass transistor ──────────────────────────────────────────────────────────
M2 vout net3 vin vin PMOS L={l_m2} W={w_m2} m={m_m2}
+ ad={ad_m2} as={as_m2} pd={pd_m2} ps={ps_m2} nrd={nrd_m2} nrs={nrs_m2}

* ── Compensation ─────────────────────────────────────────────────────────────
R2  net3 net34 {r_comp}
C0  net34 vout {c_comp}

* ── Feedback divider ─────────────────────────────────────────────────────────
R0  vout  net30 {r_fb_top}
R1  net30 vss   {r_fb_bot}

* ── Load ─────────────────────────────────────────────────────────────────────
R_load  vout vss {r_load}
C2      vout vss {c_out}

.include {model_path}
.options RELTOL=1e-4 ABSTOL=1e-12 VNTOL=1e-7 ITL4=50

* ── Operating-point analysis ─────────────────────────────────────────────────
* Each @device[param] is written to a separate 2-column file (x=DC_scale, y=value).
* Python reads data[0,1] to get the value.  PMOS Vgs/Vds are negative; abs() applied
* on the Python side.  scale x may be VIN_SRC at op (harmless).

.control

op

* M6 — NMOS 1x bias reference
wrdata {out_m6_gm}  @m6[gm]
wrdata {out_m6_gds} @m6[gds]
wrdata {out_m6_id}  @m6[id]
wrdata {out_m6_vgs} @m6[vgs]
wrdata {out_m6_vds} @m6[vds]

* M5 — NMOS 10x tail mirror
wrdata {out_m5_gm}  @m5[gm]
wrdata {out_m5_gds} @m5[gds]
wrdata {out_m5_id}  @m5[id]
wrdata {out_m5_vgs} @m5[vgs]
wrdata {out_m5_vds} @m5[vds]

* M0 — NMOS 10x diff pair non-inv (VREF)
wrdata {out_m0_gm}  @m0[gm]
wrdata {out_m0_gds} @m0[gds]
wrdata {out_m0_id}  @m0[id]
wrdata {out_m0_vgs} @m0[vgs]
wrdata {out_m0_vds} @m0[vds]

* M1 — NMOS 10x diff pair inv (feedback)
wrdata {out_m1_gm}  @m1[gm]
wrdata {out_m1_gds} @m1[gds]
wrdata {out_m1_id}  @m1[id]
wrdata {out_m1_vgs} @m1[vgs]
wrdata {out_m1_vds} @m1[vds]

* M4 — PMOS 10x active load diode-connected
wrdata {out_m4_gm}  @m4[gm]
wrdata {out_m4_gds} @m4[gds]
wrdata {out_m4_id}  @m4[id]
wrdata {out_m4_vgs} @m4[vgs]
wrdata {out_m4_vds} @m4[vds]

* M3 — PMOS 10x active load output (EA output)
wrdata {out_m3_gm}  @m3[gm]
wrdata {out_m3_gds} @m3[gds]
wrdata {out_m3_id}  @m3[id]
wrdata {out_m3_vgs} @m3[vgs]
wrdata {out_m3_vds} @m3[vds]

* M2 — PMOS 100x pass transistor
wrdata {out_m2_gm}  @m2[gm]
wrdata {out_m2_gds} @m2[gds]
wrdata {out_m2_id}  @m2[id]
wrdata {out_m2_vgs} @m2[vgs]
wrdata {out_m2_vds} @m2[vds]

.endc

.end
